#!/bin/sh
# Block a push when the committed universal bin/ccq is stale vs source (the plugin
# ships bin/ccq with no build step). Thin wrapper — logic is in the versioned
# script. Enable once with `make install-hooks` (sets core.hooksPath=.githooks).
# Bypass with `git push --no-verify` (CI still checks bin/ccq is universal + version).
exec sh "$(git rev-parse --show-toplevel)/scripts/check-bin-fresh.sh"
